# Copy this file to .env and adjust values for your environment.
# Shell environment variables override .env and .env.local.

NODE_ENV=development
JWT_SECRET=change-me

# Listener settings
PORT=80
PORT_HTTPS=443
ALLOW_HTTP=true
ALLOW_HTTPS=false
API_URL=

# Gameplay store
GAME_DB_DRIVER=mongo
GAME_DB_URL=
GAME_DB_HOST=127.0.0.1
GAME_DB_PORT=27017
GAME_DB_NAME=tcgengine
GAME_DB_USER=
GAME_DB_PASS=
GAME_DB_SSL=false

# Operational store
OPS_DB_DRIVER=mongo
OPS_DB_URL=
OPS_DB_HOST=127.0.0.1
OPS_DB_PORT=27017
OPS_DB_NAME=tcgengine_ops
OPS_DB_USER=
OPS_DB_PASS=
OPS_DB_SSL=false

# Example SQL Server Integrated Security strings:
# GAME_DB_DRIVER=mssql
# GAME_DB_URL='Data Source=DEVPC;Integrated Security=True;Database=tcgengine;Encrypt=False;TrustServerCertificate=False'
# OPS_DB_DRIVER=mssql
# OPS_DB_URL='Data Source=DEVPC;Integrated Security=True;Database=tcgengine_ops;Encrypt=False;TrustServerCertificate=False'

# Shared Mongo connection if either store uses MongoDB
MONGO_URI=
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DB=tcgengine
MONGO_USER=
MONGO_PASS=

# Transport tuning
NETWORK_STACK=node
HTTP_COMPRESSION_ENABLED=true
HTTP_COMPRESSION_THRESHOLD=1024
NETWORK_SOCKET_NO_DELAY=true
NETWORK_SOCKET_KEEP_ALIVE=true
NETWORK_KEEP_ALIVE_INITIAL_DELAY_MS=1000
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_MAX_REQUESTS_PER_SOCKET=0

# Realtime and admin operations
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/ws
RCON_ENABLED=false
RCON_HOST=127.0.0.1
RCON_PORT=27090
RCON_PASSWORD=
RBAC_LEGACY_ADMIN_FALLBACK=true

# Email
SMTP_ENABLED=false
SMTP_EMAIL=
SMTP_SERVER=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
